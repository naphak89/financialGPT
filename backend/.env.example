# Copy to .env on the server (never commit .env).

JWT_SECRET=use-a-long-random-string-in-production

# CORS: comma-separated origins for your deployed frontend
CORS_ORIGINS=http://localhost:3000

# Market charts (https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=

# RAG + news/market Q&A (same keys as local langchain-rag-tutorial/.env)
DEEPSEEK_API_KEY=
NVIDIA_API_KEY=

# Optional overrides (defaults work inside the official image)
# DATABASE_URL=sqlite:////data/users.db
# CHROMA_PATH=/app/chroma
